   1.0389e+00
   1.9441e+00
   3.2569e+00

% Construct K and check closed loop stability
K = double(L) / double(X)
K =
  -7.5648e+00   3.7632e+00  -2.8232e+03  -8.9542e+01
Acl = At + But(:,2)*K;
eig(Acl)
ans =
  -4.4633e-01 + 1.1030e+00i
  -4.4633e-01 - 1.1030e+00i
  -2.7132e-03              
  -3.9524e-05              

% stabilizing state feedback control (using u1 and u2)
n = size(At,1);
m = 2;

% declare variables
X = sdpvar(n,n,'symmetric');
L = sdpvar(m,n);

% declare LMIs
LMI1 = At*X+X*At'+But*L+L'*But';
LMI2 = X;

LMI = set(LMI1 < 0) + set(LMI2 > 0);
options = sdpsettings('solver','sedumi');
solution =solvesdp(LMI,[],options)
