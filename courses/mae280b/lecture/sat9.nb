   RowBox[{"6.673", "*", 
    RowBox[{"10", "^", 
     RowBox[{"(", 
      RowBox[{"-", "11"}], ")"}]}]}]}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{"6.673", " ", "N", " ", 
    RowBox[{
     RowBox[{"m", "^", "2"}], "/", 
