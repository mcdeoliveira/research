Cell["Newton' s Law", "Subsection",
 CellChangeTimes->{{3.566591764758292*^9, 3.566591771400609*^9}}],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{"R", ",", "U1", ",", "U2", ",", "F"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"NewtonsLaw", "=", 
  RowBox[{
   RowBox[{"m", " ", 
    RowBox[{
     RowBox[{"R", "''"}], "[", "t", "]"}]}], "-", 
   RowBox[{"F", "[", "t", "]"}], "-", 
   RowBox[{"U", "[", "t", "]"}]}]}]}], "Input",
 CellChangeTimes->{{3.5665918416073313`*^9, 3.5665918885727587`*^9}, {
  3.5665922044061213`*^9, 3.566592206140709*^9}, {3.56659335550504*^9, 
  3.5665933572401247`*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"-", 
   RowBox[{"F", "[", "t", "]"}]}], "-", 
  RowBox[{"U", "[", "t", "]"}], "+", 
  RowBox[{"m", " ", 
   RowBox[{
    SuperscriptBox["R", "\[Prime]\[Prime]",
     MultilineFunction->None], "[", "t", "]"}]}]}]], "Output",
 CellChangeTimes->{3.566840543297695*^9, 3.566867941970862*^9}]
}, Open  ]],

Cell["should be equal to zero, where F is the gravitational force:", "Text",
 CellChangeTimes->{{3.566592040268053*^9, 3.566592064356708*^9}, {
  3.5665933920198507`*^9, 3.566593394923502*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"gravityRule", "=", 
  RowBox[{
   RowBox[{"F", "[", "t", "]"}], "\[Rule]", 
   RowBox[{
    RowBox[{"-", "k"}], " ", 
    RowBox[{"m", "/", 
     RowBox[{
      RowBox[{"r", "[", "t", "]"}], "^", "2"}]}], " ", 
    RowBox[{
     RowBox[{"R", "[", "t", "]"}], "/", 
     RowBox[{"r", "[", "t", "]"}]}]}]}]}]], "Input",
 CellChangeTimes->{{3.566592066130719*^9, 3.56659210916693*^9}, {
   3.5665922143238573`*^9, 3.566592216596456*^9}, 3.5665945196908493`*^9}],

Cell[BoxData[
 RowBox[{
  RowBox[{"F", "[", "t", "]"}], "\[Rule]", 
  RowBox[{"-", 
   FractionBox[
    RowBox[{"k", " ", "m", " ", 
     RowBox[{"R", "[", "t", "]"}]}], 
    SuperscriptBox[
     RowBox[{"r", "[", "t", "]"}], "3"]]}]}]], "Output",
 CellChangeTimes->{3.566840555978263*^9, 3.5668679419909067`*^9}]
}, Open  ]],

