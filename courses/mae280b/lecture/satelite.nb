Cell[CellGroupData[{

Cell["\<\
Controllability, Observability and Transfer - function representation\
\>", "Section",
 CellChangeTimes->{{3.566614284128173*^9, 3.5666143053978252`*^9}}],

Cell["\<\
We can transform the MIMO system into transfer function - form\
\>", "Text",
 CellChangeTimes->{{3.566614322686846*^9, 3.566614345726508*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"tf", "=", 
  RowBox[{"TransferFunctionModel", "[", "linearizedSystem", "]"}]}]], "Input",\

 CellChangeTimes->{{3.566614215058401*^9, 3.566614235758912*^9}, 
   3.566614315578326*^9, {3.566614349623439*^9, 3.5666143499428253`*^9}}],

Cell[BoxData[
 TagBox[
  SubsuperscriptBox[
   FormBox[
    TagBox[
     RowBox[{"(", "\[NoBreak]", GridBox[{
        {
         FractionBox[
          RowBox[{
           RowBox[{"-", 
            SuperscriptBox["\[FormalS]", "4"]}], "-", 
           RowBox[{
            SuperscriptBox["\[FormalS]", "2"], " ", 
            SuperscriptBox["\[Omega]", "2"]}], "+", 
           RowBox[{
            SuperscriptBox["\[FormalS]", "2"], " ", 
            RowBox[{"(", 
             RowBox[{
              SuperscriptBox["\[FormalS]", "2"], "+", 
              FractionBox["1", "m"], "+", 
              SuperscriptBox["\[Omega]", "2"]}], ")"}]}]}], 
          RowBox[{
           RowBox[{
            SuperscriptBox["\[Omega]", "2"], " ", 
            SuperscriptBox["\[FormalS]", "2"]}], "+", 
           SuperscriptBox["\[FormalS]", "4"]}]], 
         FractionBox[
          RowBox[{
           RowBox[{"-", 
            SuperscriptBox["\[FormalS]", "4"]}], "-", 
           RowBox[{
            SuperscriptBox["\[FormalS]", "2"], " ", 
            SuperscriptBox["\[Omega]", "2"]}], "+", 
           RowBox[{"\[FormalS]", " ", 
            RowBox[{"(", 
             RowBox[{
              SuperscriptBox["\[FormalS]", "3"], "+", 
              FractionBox[
               RowBox[{"2", " ", "\[Omega]"}], "m"], "+", 
              RowBox[{"\[FormalS]", " ", 
               SuperscriptBox["\[Omega]", "2"]}]}], ")"}]}]}], 
          RowBox[{
           RowBox[{
            SuperscriptBox["\[Omega]", "2"], " ", 
            SuperscriptBox["\[FormalS]", "2"]}], "+", 
           SuperscriptBox["\[FormalS]", "4"]}]]},
        {
         FractionBox[
          RowBox[{
           RowBox[{"-", 
            SuperscriptBox["\[FormalS]", "4"]}], "-", 
           RowBox[{
            SuperscriptBox["\[FormalS]", "2"], " ", 
            SuperscriptBox["\[Omega]", "2"]}], "+", 
           RowBox[{
            SuperscriptBox["\[FormalS]", "2"], " ", 
            RowBox[{"(", 
             RowBox[{
              SuperscriptBox["\[FormalS]", "2"], "+", 
              FractionBox["\[FormalS]", "m"], "+", 
              SuperscriptBox["\[Omega]", "2"]}], ")"}]}]}], 
          RowBox[{
           RowBox[{
            SuperscriptBox["\[Omega]", "2"], " ", 
            SuperscriptBox["\[FormalS]", "2"]}], "+", 
           SuperscriptBox["\[FormalS]", "4"]}]], 
         FractionBox[
          RowBox[{
           RowBox[{"-", 
            SuperscriptBox["\[FormalS]", "4"]}], "-", 
           RowBox[{
            SuperscriptBox["\[FormalS]", "2"], " ", 
            SuperscriptBox["\[Omega]", "2"]}], "+", 
           RowBox[{
            SuperscriptBox["\[FormalS]", "2"], " ", 
            RowBox[{"(", 
             RowBox[{
              SuperscriptBox["\[FormalS]", "2"], "+", 
              RowBox[{"\[Omega]", " ", 
               RowBox[{"(", 
                RowBox[{
                 FractionBox["2", "m"], "+", "\[Omega]"}], ")"}]}]}], 
             ")"}]}]}], 
          RowBox[{
           RowBox[{
            SuperscriptBox["\[Omega]", "2"], " ", 
            SuperscriptBox["\[FormalS]", "2"]}], "+", 
           SuperscriptBox["\[FormalS]", "4"]}]]},
        {
         FractionBox[
          RowBox[{
           RowBox[{"-", 
            SuperscriptBox["\[FormalS]", "4"]}], "-", 
           RowBox[{
            SuperscriptBox["\[FormalS]", "2"], " ", 
            SuperscriptBox["\[Omega]", "2"]}], "+", 
           RowBox[{
            SuperscriptBox["\[FormalS]", "2"], " ", 
            RowBox[{"(", 
             RowBox[{
              SuperscriptBox["\[FormalS]", "2"], "+", 
              SuperscriptBox["\[Omega]", "2"], "-", 
              FractionBox[
               RowBox[{"2", " ", "\[Omega]"}], 
               RowBox[{"m", " ", 
                RowBox[{
                 OverscriptBox["r", "_"], "[", "t", "]"}]}]]}], ")"}]}]}], 
          RowBox[{
           RowBox[{
            SuperscriptBox["\[Omega]", "2"], " ", 
            SuperscriptBox["\[FormalS]", "2"]}], "+", 
           SuperscriptBox["\[FormalS]", "4"]}]], 
         FractionBox[
          RowBox[{
           RowBox[{"-", 
            SuperscriptBox["\[FormalS]", "4"]}], "-", 
           RowBox[{
            SuperscriptBox["\[FormalS]", "2"], " ", 
            SuperscriptBox["\[Omega]", "2"]}], "+", 
           FractionBox[
            RowBox[{"\[FormalS]", " ", 
             RowBox[{"(", 
              RowBox[{
               SuperscriptBox["\[FormalS]", "2"], "-", 
               RowBox[{"3", " ", 
                SuperscriptBox["\[Omega]", "2"]}], "+", 
               RowBox[{"\[FormalS]", " ", "m", " ", 
                RowBox[{"(", 
                 RowBox[{
                  SuperscriptBox["\[FormalS]", "2"], "+", 
                  SuperscriptBox["\[Omega]", "2"]}], ")"}], " ", 
                RowBox[{
                 OverscriptBox["r", "_"], "[", "t", "]"}]}]}], ")"}]}], 
            RowBox[{"m", " ", 
             RowBox[{
              OverscriptBox["r", "_"], "[", "t", "]"}]}]]}], 
          RowBox[{
           RowBox[{
            SuperscriptBox["\[Omega]", "2"], " ", 
            SuperscriptBox["\[FormalS]", "2"]}], "+", 
           SuperscriptBox["\[FormalS]", "4"]}]]}
       },
       AllowScriptLevelChange->False,
       BaseStyle->{Deployed -> False},
       GridBoxAlignment->{
        "Columns" -> {{Center}}, "ColumnsIndexed" -> {}, 
         "Rows" -> {{Baseline}}, "RowsIndexed" -> {}},
       GridBoxItemStyle->{
        "ItemsIndexed" -> {{{1, 1}, {}} -> {
            Deployed -> True, ShowStringCharacters -> False}, {{}, {1, 
             1}} -> {Deployed -> True, ShowStringCharacters -> False}}},
       GridBoxSpacings->{"Columns" -> {
           Offset[0.27999999999999997`], {
            Offset[0.7]}, 
           Offset[0.27999999999999997`]}, "ColumnsIndexed" -> {}, "Rows" -> {
           Offset[0.2], {
            Offset[0.4]}, 
           Offset[0.2]}, "RowsIndexed" -> {}}], "\[NoBreak]", ")"}],
     Function[BoxForm`e$, 
      MatrixForm[BoxForm`e$]]],
    StandardForm], 
   FormBox[
    StyleBox["\<\"\[InvisibleSpace]\"\>",
     ShowStringCharacters->False],
    StandardForm], 
   FormBox[
    StyleBox["\<\"\[ScriptCapitalT]\"\>",
     Editable->False,
     ShowStringCharacters->False],
    StandardForm],
   MultilineFunction->None],
  {TransferFunctionModel, {
   SamplingPeriod -> None, {
    Control`CommonDump`pVar -> \[FormalS], Hash -> 1612092253}}}]], "Output",
 CellChangeTimes->{3.566841730881652*^9, 3.566841774924407*^9, 
  3.566867942881323*^9}]
}, Open  ]],

Cell["\<\
The common denominator have degree 4, as is the order of the state space model.

However, because the system is not observable, there must be pole-zero \
cancelations, which in this case are revealed by canceling a \
\[LineSeparator]pole and zero a the origin:\
\>", "Text",
 CellChangeTimes->{{3.5666143620903797`*^9, 3.566614483009488*^9}, 
   3.566614531712131*^9}],

