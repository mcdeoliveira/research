         MultilineFunction->None], "[", "t", "]"}]}], "+", 
      RowBox[{"m", " ", 
       RowBox[{"r", "[", "t", "]"}], " ", 
       RowBox[{
        SuperscriptBox["\[Theta]", "\[Prime]\[Prime]",
         MultilineFunction->None], "[", "t", "]"}]}]}]}
   },
   BaselinePosition->{Baseline, {1, 1}},
