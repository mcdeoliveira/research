Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{"er", ",", "e\[Theta]"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"cylindricalRule", "=", 
  RowBox[{"{", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"er", "[", "t", "]"}], "->", 
