      RowBox[{
       RowBox[{"u1", "[", "t", "]"}], 
       RowBox[{"er", "[", "t", "]"}]}], "+", 
      RowBox[{
       RowBox[{"u2", "[", "t", "]"}], 
       RowBox[{"e\[Theta]", "[", "t", "]"}]}]}]}]}], "\[IndentingNewLine]", 
   "}"}]}]}], "Input",
