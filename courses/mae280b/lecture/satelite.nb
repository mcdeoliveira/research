     "RowsIndexed" -> {}}],
  ColumnForm[{$CellContext`k $CellContext`m \
$CellContext`r[$CellContext`t]^(-2) - $CellContext`u1[$CellContext`t] - \
$CellContext`m $CellContext`r[$CellContext`t] 
