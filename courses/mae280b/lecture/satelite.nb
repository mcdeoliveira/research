Cell["We compute the controllability matrix :", "Text",
 CellChangeTimes->{{3.566612274044689*^9, 3.566612281788684*^9}}],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"ctrl", "=", 
   RowBox[{"ControllabilityMatrix", "[", "linearizedSystem2", "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"MatrixForm", "[", "ctrl", "]"}]}], "Input",
 CellChangeTimes->{{3.566612263305039*^9, 3.5666122644100933`*^9}, 
   3.56661244247432*^9}],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {"0", "0", 
      FractionBox[
       RowBox[{"2", " ", "\[Omega]"}], "m"], "0"},
     {"0", 
      FractionBox["1", 
       RowBox[{"m", " ", 
        RowBox[{
         OverscriptBox["r", "_"], "[", "t", "]"}]}]], "0", 
      RowBox[{"-", 
       FractionBox[
        RowBox[{"4", " ", 
         SuperscriptBox["\[Omega]", "2"]}], 
        RowBox[{"m", " ", 
         RowBox[{
          OverscriptBox["r", "_"], "[", "t", "]"}]}]]}]},
     {"0", 
      FractionBox[
       RowBox[{"2", " ", "\[Omega]"}], "m"], "0", 
      RowBox[{"-", 
       FractionBox[
        RowBox[{"2", " ", 
         SuperscriptBox["\[Omega]", "3"]}], "m"]}]},
     {
      FractionBox["1", 
       RowBox[{"m", " ", 
        RowBox[{
         OverscriptBox["r", "_"], "[", "t", "]"}]}]], "0", 
      RowBox[{"-", 
       FractionBox[
        RowBox[{"4", " ", 
         SuperscriptBox["\[Omega]", "2"]}], 
        RowBox[{"m", " ", 
         RowBox[{
          OverscriptBox["r", "_"], "[", "t", "]"}]}]]}], "0"}
    },
    GridBoxAlignment->{
     "Columns" -> {{Center}}, "ColumnsIndexed" -> {}, "Rows" -> {{Baseline}}, 
      "RowsIndexed" -> {}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "ColumnsIndexed" -> {}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}, "RowsIndexed" -> {}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[BoxForm`e$]]]], "Output",
 CellChangeTimes->{3.5668413728276997`*^9, 3.566867942714575*^9}]
