         RowBox[{"\[Theta]", "[", "t", "]"}], "]"}]}], ",", 
       RowBox[{"Cos", "[", 
        RowBox[{"\[Theta]", "[", "t", "]"}], "]"}]}], "}"}]}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"R", "[", "t", "]"}], "\[Rule]", 
     RowBox[{
      RowBox[{"r", "[", "t", "]"}], " ", 
      RowBox[{"er", "[", "t", "]"}]}]}], ",", "\[IndentingNewLine]", 
