#X text 419 103 <-microphone 2;
#X text 101 114 <-microphone 1;
#N canvas 0 22 450 300 info 1;
#X text 25 9 this patch shows the problem of microphone placement and
the distortion that can occur of mics are two close together. microphone
1 is simulated simply by picking up a source sound directly. microphone
2 is simulated with a delayed copy of the source sound.;
#X text 28 84 you can adjust the distance in millimeters (yelow numebr
box) between microphones. the green box reports the time delay at these
distances. with sine tones \, phase cancellation is clearly audible
\, and is reflected in the magnitude spectrum. with a noise source
\, comb filterring can be heard.;
#X text 30 167 NOTE: changing the delay will result in a discontinuity
in the output waveform. in the case of noise \, this will be inaudible
(noise is just a series of discontinuities \, so one more doesn't matter)
but it will sound like a click in the sine tones.;
#X restore 35 -33 pd info;
#X text 373 -32 <-centimeters between 'microphones';
#X obj 287 16 / 344;
#X obj 287 -5 * 10;
#X text 423 37 <-time delay (milliseconds)between 'mics';
#X msg 35 10 \; pd dsp 1;
#X obj 35 -11 loadbang;
#X text 697 105 choose between sin tones or noise;
